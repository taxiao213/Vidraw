{
  "compilerOptions": {
    "target": "ESNext",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "allowSyntheticDefaultImports": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "emitDeclarationOnly": true,
    "paths": {
      "@vidraw/common": ["./common/src/index.ts"],
      "@vidraw/common/*": ["./common/src/*"],
      "@vidraw/element": ["./element/src/index.ts"],
      "@vidraw/element/*": ["./element/src/*"],
      "@vidraw/vidraw": ["./excalidraw/index.tsx"],
      "@vidraw/vidraw/*": ["./excalidraw/*"],
      "@vidraw/excalidraw": ["./excalidraw/index.tsx"],
      "@vidraw/excalidraw/*": ["./excalidraw/*"],
      "@vidraw/math": ["./math/src/index.ts"],
      "@vidraw/math/*": ["./math/src/*"],
      "@vidraw/utils": ["./utils/src/index.ts"],
      "@vidraw/utils/*": ["./utils/src/*"]
    }
  }
}
